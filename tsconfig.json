{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noImplicitAny": true
  },
  "files": ["src/types/express.d.ts"],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
